Options -Indexes
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /api/v1/
# Preserve the Authorization header for bearer-token auth.
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
# Route everything that isn't a real file/dir to the front controller.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]
</IfModule>
